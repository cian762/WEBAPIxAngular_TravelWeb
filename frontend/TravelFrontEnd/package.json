    "@googlemaps/js-api-loader": "^2.0.2",
    "bootstrap-icons": "^1.13.1",
    "flatpickr": "^4.6.13",
    "ngx-cookie-service": "^21.3.1",
    "remixicon": "^4.9.1",
    "rxjs": "~7.8.0",
